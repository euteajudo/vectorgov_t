{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@vectorgov-t/schemas": ["./packages/schemas/src/index.ts"],
      "@vectorgov-t/schemas/*": ["./packages/schemas/src/*"],
      "@vectorgov-t/shared": ["./packages/shared/src/index.ts"],
      "@vectorgov-t/shared/*": ["./packages/shared/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".wrangler"]
}
