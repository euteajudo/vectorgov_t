# ==============================================================================
# VECTORGOV_T - Variáveis de ambiente (template)
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite .env ou .dev.vars no git.
# ==============================================================================

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=a89dbdb0224cd8d2292cda8a038bc297
CLOUDFLARE_API_TOKEN=

# --- Gemini via Cloudflare AI Gateway (BYOK) ---
# A chave do Gemini fica em Stored Keys/BYOK no AI Gateway `vectorgov-t`
# (dashboard Cloudflare → AI → AI Gateway). O Worker só usa o TOKEN do gateway,
# enviado no header cf-aig-authorization. Setar como secret do Worker:
#   cd apps/mcp-server && npx wrangler secret put CF_AIG_TOKEN
# Em dev local: apps/mcp-server/.dev.vars com CF_AIG_TOKEN=...
CF_AIG_TOKEN=
# Opcional: override da base do endpoint compat (default no código aponta para
# o gateway `vectorgov-t`).
# CF_AIG_BASE_URL=

# --- Ingestion API (Container) ---
# Secret compartilhado entre Worker MCP e Container Python
INGESTION_API_SECRET=

# --- Node TLS workaround ---
# Necessário no Windows quando antivírus intercepta TLS
NODE_OPTIONS=--use-system-ca
