# ==============================================================================
# VECTORGOV_T - Variáveis de ambiente (template)
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite .env ou .dev.vars no git.
# ==============================================================================

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=a89dbdb0224cd8d2292cda8a038bc297
CLOUDFLARE_API_TOKEN=

# --- Google Gemini API ---
# Obter em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Ingestion API (Container) ---
# Secret compartilhado entre Worker MCP e Container Python
INGESTION_API_SECRET=

# --- Node TLS workaround ---
# Necessário no Windows quando antivírus intercepta TLS
NODE_OPTIONS=--use-system-ca
